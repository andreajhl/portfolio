{"ast":null,"code":"import * as TYPES from \"./types\";\nimport apiService from \"../../utils/apiService\";\nimport { handleApiErrors, handleApiResponseFailure, handleApiResponseSuccess } from \"../../utils\";\nimport * as API_PATHS from \"./paths\";\nexport var fetchCelebritySections = function fetchCelebritySections(params) {\n  return function (dispatch) {\n    var TYPE = TYPES.FETCH_CELEBRITIES_SECTIONS;\n    var FINAL_PATH = API_PATHS.FETCH_CELEBRITY_SECTIONS;\n    dispatch({\n      type: TYPE\n    });\n    return apiService({\n      method: \"GET\",\n      action: TYPE,\n      path: FINAL_PATH,\n      params: params\n    }).then(function (res) {\n      if (\"status\" in res.data && res.data.status === \"ERROR\") {\n        handleApiResponseFailure(dispatch, TYPE, res);\n      } else {\n        handleApiResponseSuccess(dispatch, TYPE, res);\n        dispatch({\n          type: \"\".concat(TYPE, \"_COMPLETED\"),\n          payload: res\n        });\n      }\n    }).catch(function (err) {\n      handleApiErrors(dispatch, TYPE, err);\n    });\n  };\n};\nexport var setPlayingVideo = function setPlayingVideo(videoKey) {\n  return {\n    type: TYPES.PLAY_VIDEO,\n    payload: videoKey\n  };\n};","map":null,"metadata":{},"sourceType":"module"}