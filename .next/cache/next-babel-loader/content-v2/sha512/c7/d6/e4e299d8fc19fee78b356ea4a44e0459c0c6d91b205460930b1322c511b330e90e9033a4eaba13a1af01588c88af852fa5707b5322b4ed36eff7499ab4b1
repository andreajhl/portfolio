{"ast":null,"code":"import * as types from \"./types\";\nimport apiService from \"../../utils/apiService\";\nimport { handleApiErrors, handleApiResponseFailure, handleApiResponseSuccess } from \"../../utils\";\nimport * as API_PATHS from \"./paths\";\nimport { history } from \"../../../routing/History\";\nimport * as PATHS from \"../../../routing/Paths\";\nexport var postProcessSubscription = function postProcessSubscription(subscription_data) {\n  var TYPE = types.PROCESS_SUBSCRIPTION_REQUEST;\n  var FINAL_PATH = API_PATHS.PROCESS_SUBSCRIPTION_PATH;\n  return new Promise(function (resolutionFunc, rejectionFunc) {\n    apiService({\n      method: 'POST',\n      action: TYPE,\n      path: FINAL_PATH,\n      async: true,\n      body: subscription_data\n    }).then(function (res) {\n      if (res.data.status === 'OK') {\n        resolutionFunc(res.data.data);\n      } else {\n        rejectionFunc(res.data.error);\n      }\n    }).catch(function (err) {\n      rejectionFunc(err);\n    });\n  });\n};\nexport var fetchUserSubscriptionsList = function fetchUserSubscriptionsList(user_data) {\n  return function (dispatch) {\n    var TYPE = types.FETCH_USER_SUBSCRIPTIONS_REQUEST;\n    var FINAL_PATH = API_PATHS.USER_SUBSCRIPTIONS_PATH;\n    dispatch({\n      type: TYPE,\n      payload: {}\n    });\n    apiService({\n      method: \"GET\",\n      action: TYPE,\n      path: FINAL_PATH,\n      async: true,\n      body: null\n    }).then(function (res) {\n      if (res.data.status === \"OK\") {\n        handleApiResponseSuccess(dispatch, TYPE, res);\n        dispatch({\n          type: \"\".concat(TYPE, \"_COMPLETED\"),\n          payload: res\n        });\n      } else {\n        handleApiResponseFailure(dispatch, TYPE, res);\n      }\n    }).catch(function (err) {\n      handleApiErrors(dispatch, TYPE, {\n        data: {\n          api_error: err,\n          error: \"Server 500\"\n        }\n      });\n    });\n  };\n};","map":null,"metadata":{},"sourceType":"module"}