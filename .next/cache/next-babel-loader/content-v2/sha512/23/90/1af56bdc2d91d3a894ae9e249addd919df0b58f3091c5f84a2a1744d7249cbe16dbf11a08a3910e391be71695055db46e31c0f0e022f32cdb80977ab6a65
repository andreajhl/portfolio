{"ast":null,"code":"import { useState, useEffect } from \"react\";\nconst defaultItemRef = {\n  current: {\n    readyState: 0\n  }\n};\nconst LOADED = 4;\n\nconst useLoad = (itemRef = defaultItemRef, defaultIsLoaded = false) => {\n  const {\n    0: isLoaded,\n    1: setIsLoaded\n  } = useState(defaultIsLoaded);\n\n  const onLoad = () => setIsLoaded(true);\n\n  useEffect(() => {\n    if (itemRef.current.readyState !== LOADED) return;\n    onLoad();\n  }, [itemRef]);\n  return [isLoaded, onLoad];\n};\n\nexport default useLoad;","map":null,"metadata":{},"sourceType":"module"}