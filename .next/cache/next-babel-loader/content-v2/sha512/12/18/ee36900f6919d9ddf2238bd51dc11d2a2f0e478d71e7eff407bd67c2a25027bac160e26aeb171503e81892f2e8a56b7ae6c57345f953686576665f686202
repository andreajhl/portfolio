{"ast":null,"code":"import { useEffect } from \"react\";\nimport { useRouter } from \"next/router\";\n\nfunction Redirect({\n  to,\n  push = false\n}) {\n  const router = useRouter();\n  const method = push ? router.push : router.replace;\n  useEffect(() => {\n    if (!to) throw new TypeError(\"The argument 'to' is required\");\n    method(to);\n  }, [method, to]);\n  return null;\n}\n\nexport { Redirect };","map":null,"metadata":{},"sourceType":"module"}