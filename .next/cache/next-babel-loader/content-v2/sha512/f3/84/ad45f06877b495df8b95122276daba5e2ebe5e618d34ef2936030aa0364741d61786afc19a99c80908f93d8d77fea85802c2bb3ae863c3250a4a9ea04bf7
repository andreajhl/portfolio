{"ast":null,"code":"import { useState, useEffect } from \"react\";\nimport debounce from \"lodash.debounce\";\nimport getWindow from \"./getWindow\";\n\nconst useGetViewportWidthOnResize = (updateTimeout = 500) => {\n  const {\n    0: windowWidth,\n    1: setWindowWidth\n  } = useState(getWindow().innerWidth);\n  useEffect(() => {\n    const updateSize = () => {\n      setWindowWidth(window.innerWidth);\n    };\n\n    if (!windowWidth) updateSize();\n    const debouncedUpdateSize = debounce(updateSize, updateTimeout);\n    window.addEventListener(\"resize\", debouncedUpdateSize);\n    return () => {\n      window.removeEventListener(\"resize\", debouncedUpdateSize);\n    };\n  }, []);\n  return windowWidth;\n};\n\nexport default useGetViewportWidthOnResize;","map":null,"metadata":{},"sourceType":"module"}