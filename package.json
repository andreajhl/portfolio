{
  "name": "famosos-frontend",
  "version": "2.0.11",
  "description": "Famosos Webapp",
  "private": true,
  "scripts": {
    "dev": "env-cmd -f .env next dev",
    "build": "next build",
    "build-local": "env-cmd -f .env.local next build",
    "build-development": "env-cmd -f .env.development next build",
    "build-testing": "env-cmd -f .env.testing next build",
    "build-qa": "env-cmd -f .env.qa next build",
    "build-production": "env-cmd -f .env.production next build",
    "type-check": "echo 'tsc -p tsconfig.json --pretty --noEmit'",
    "start": "next start -p 8081",
    "format": "prettier --write .",
    "lint": "eslint . --ext ts --ext tsx --ext js",
    "test": "jest",
    "test-all": "yarn lint && yarn type-check && yarn test",
    "prepare": "husky install",
    "build-check": "rm -rf .next && npm run build",
    "check-staged-files": "lint-staged",
    "extract:i18n": "formatjs extract {pages,react-app}/**/*.{js,tsx} --format crowdin --id-interpolation-pattern [sha512:contenthash:base64:6] --out-file lang/es.json",
    "compile": "formatjs compile-folder --ast --format crowdin lang compiled-lang"
  },
  "lint-staged": {
    "*.(js|ts|jsx|tsx)": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@auth0/auth0-react": "^1.2.0",
    "@auth0/nextjs-auth0": "^0.16.1",
    "@formatjs/cli": "^4.2.11",
    "@next/bundle-analyzer": "^10.0.7",
    "@paypal/react-paypal-js": "^7.0.0",
    "@sentry/nextjs": "^6.4.1",
    "@stripe/react-stripe-js": "^1.4.1",
    "@stripe/stripe-js": "^1.12.1",
    "axios": "^0.21.1",
    "bootstrap": "^4.6.0",
    "classnames": "^2.2.6",
    "cookie": "^0.4.1",
    "env-cmd": "^10.1.0",
    "firebase": "^8.2.6",
    "fscreen": "^1.1.0",
    "is-symbol": "^1.0.3",
    "isbot": "^3.0.25",
    "jwt-decode": "^3.1.2",
    "lodash.debounce": "^4.0.8",
    "mixpanel-browser": "^2.41.0",
    "moment": "^2.29.1",
    "next": "^10.1.0",
    "next-redux-wrapper": "^6.0.2",
    "parse-full-name": "^1.2.5",
    "path-to-regexp": "^6.2.0",
    "react": "^16.13.1",
    "react-albus": "^2.0.0",
    "react-async-script-loader": "^0.3.0",
    "react-bootstrap": "^1.4.3",
    "react-confirm-alert": "^2.7.0",
    "react-datepicker": "^3.4.1",
    "react-dom": "^16.13.1",
    "react-flags-select": "^2.1.1",
    "react-gtm-module": "^2.0.11",
    "react-headroom": "^3.1.0",
    "react-html-parser": "^2.0.2",
    "react-image-crop": "^8.6.9",
    "react-infinite-scroll-component": "^5.1.0",
    "react-intl": "^5.18.1",
    "react-lazy-load-image-component": "^1.5.1",
    "react-loading-skeleton": "^2.2.0",
    "react-number-format": "^4.4.4",
    "react-phone-input-2": "^2.13.9",
    "react-redux": "^7.2.2",
    "react-resizable": "^1.11.0",
    "react-select": "^4.3.1",
    "react-star-rating-component": "^1.4.1",
    "react-stripe-elements": "^6.1.2",
    "react-tagsinput": "^3.19.0",
    "react-textarea-autosize": "^8.3.2",
    "react-typist": "^2.0.5",
    "react-typist-loop": "0.0.5",
    "react-window": "^1.8.6",
    "reactjs-popup": "^2.0.4",
    "redux": "^4.0.5",
    "redux-batched-actions": "^0.5.0",
    "redux-thunk": "^2.3.0",
    "rheostat": "^4.1.1",
    "styled-components": "^5.2.3",
    "ua-parser-js": "^0.7.23",
    "validator": "^13.6.0"
  },
  "devDependencies": {
    "@types/enzyme": "^3.10.8",
    "@types/enzyme-adapter-react-16": "^1.0.6",
    "@types/jest": "^25.1.4",
    "@types/lodash.debounce": "^4.0.6",
    "@types/node": "^13.9.5",
    "@types/react": "^16.14.5",
    "@types/react-image-crop": "^8.1.2",
    "@types/react-redux": "^7.1.16",
    "@types/react-select": "^4.0.15",
    "@types/react-window": "^1.8.2",
    "@typescript-eslint/eslint-plugin": "^4.15.0",
    "@typescript-eslint/parser": "^4.15.0",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^25.2.3",
    "babel-plugin-dynamic-import-node": "^2.3.3",
    "babel-plugin-formatjs": "^10.2.15",
    "babel-plugin-styled-components": "^1.12.0",
    "enzyme": "^3.11.0",
    "enzyme-adapter-react-16": "^1.15.5",
    "eslint": "^7.19.0",
    "eslint-config-prettier": "^6.10.1",
    "eslint-config-react-app": "^6.0.0",
    "eslint-plugin-flowtype": "^5.2.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-react": "^7.22.0",
    "eslint-plugin-react-hooks": "^4.2.0",
    "husky": "^6.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^25.2.3",
    "jest-enzyme": "^7.1.2",
    "jest-next-dynamic": "^1.0.1",
    "jest-react-hooks-shallow": "^1.5.1",
    "jest-watch-typeahead": "^0.5.0",
    "lint-staged": "^10.0.10",
    "node-sass": "^5.0.0",
    "prettier": "^2.0.2",
    "styled-jsx-plugin-sass": "^1.0.0",
    "typescript": "^3.8.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": "12.4.0"
  }
}
